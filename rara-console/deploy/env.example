# /etc/rara-console/env — rara-console VPC deployment config.
# Copy to /etc/rara-console/env, fill in real values, chmod 640 ubuntu:ubuntu.

# Base URL of the rara-core control surface (same VPC, over the tailnet). The console talks to it
# server-side; the SPA never sees this URL or the token below.
CORE_SURFACE_URL=http://100.x.x.x:8080

# Bearer token for the rara-core surface — MUST match rara-core's SURFACE_TOKEN.
SURFACE_TOKEN=

# Tailscale IP of THIS VM + console port, e.g. 100.x.x.x:8081, found with: tailscale ip -4
# MUST be the Tailscale address, NOT :8081 alone / 0.0.0.0 — the console must not listen on the
# public Oracle interface.
CONSOLE_ADDR=100.x.x.x:8081
