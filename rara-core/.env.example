# rara-core — local env. Copy to .env (gitignored) and fill in real values.

# Neon PostgreSQL connection string (shared with the other rara agents; rara-core owns
# the control tables — capabilities, providers, flows, flow_steps, routing_policies,
# items, item_steps, gate_decisions, gate_rules, feedback, interest_profile).
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# --- Reconciler (`core-job reconcile --loop`, VPC always-on) -------------------
# Poll interval for the level-triggered loop. Default 30s.
RECONCILE_INTERVAL_SECONDS=30
# A claimed (running) step with no heartbeat for this long is assumed dead and returned
# to the pending frontier for re-claim (minimal liveness backstop; full routing is Phase 2).
RECONCILE_STALE_SECONDS=600
# Self-healing re-activation backoff for on_demand cloudrun providers (scale-to-zero, no poll
# safety net). After a SUCCESSFUL wake the worker drains the whole queue, so the reconciler will
# not re-fire while pending work remains within this window — preventing concurrent executions
# ("swarm"). A wake that failed/timed out is retried on the next pass (it set no anchor). Default 180s.
REACTIVATE_BACKOFF_SECONDS=180

# --- Symmetric activation (P1b: real Activators) ------------------------------
# On every assignment the reconciler wakes the provider so it drains NOW (the slow poll is the
# safety net; every wake is best-effort, never fatal). Dispatch is by provider shape — cloudrun
# via Cloud Run Jobs `run`, resident via tailnet poke. Leave a section unset to make that path a
# logged no-op; unset BOTH and the reconciler is pull-only.

# Cloud Run Jobs `run` (wakes runtime=cloudrun, on_demand providers). project+region are shared
# across every job; the job is named after the provider (prefix + provider name).
CLOUD_RUN_PROJECT=
CLOUD_RUN_REGION=us-central1
# Optional namespace prepended to the provider name to form the job name (e.g. "rara-").
CLOUD_RUN_JOB_PREFIX=
# OAuth2 access token with run.jobs.run. This is a SEAM: fine for a short-lived/manual token;
# a deploy wires a refreshing service-account source in its place (see activator.go).
CLOUD_RUN_OAUTH_TOKEN=

# Tailnet poke (wakes activation=resident providers at their providers.poke_url). One token is
# shared across the tailnet and must match each worker's POKE_TOKEN. Unset = residents are not
# poked (the poll covers them).
POKE_AUTH_TOKEN=

# Per-wake HTTP timeout for both activators. Default 30s (a Cloud Run Jobs `run` cold start
# routinely passes 10s; an on_demand job has no poll fallback, so the first attempt should land).
ACTIVATE_TIMEOUT_SECONDS=30

# --- Control surface (`core-job surface`, or auto-mounted by `reconcile --loop`) ----
# The HTTP núcleo + MCP adapter (MCP over HTTP at POST /mcp). Mounted alongside the reconciler
# ticker in the SAME VPC process when SURFACE_ADDR is set (reconcile --loop), or served
# standalone (`surface`).
SURFACE_ADDR=:8080
# Service token for the surface auth (Authorization: Bearer <token>). REQUIRED — the surface
# refuses to serve without it (it is personal, but never left open). Generate a long random
# value, e.g. `openssl rand -hex 32`.
SURFACE_TOKEN=

# --- Worker shims (`core-job work --capability <cap>`) -------------------------
# The shim invokes the existing domain binary without touching its logic, then reads
# back the row it wrote. Point these at the deployed artifacts:
#   transcrever -> scribe on the Mac;  destilar -> distill in the Cloud Run image.
SCRIBE_BIN=scribe-job
DISTILL_BIN=etl-job
# distill has no per-item entry, so the shim forces a large batch to drain the queue
# (incl. the claimed transcript) in one idempotent run.
DISTILL_DRAIN_BATCH=100

# --- Curation gates (`core-job work --capability gate_barato|gate_rico`) -------
# The gate cascade (rules -> interest_profile match -> LLM-judge) consults a model ONLY on
# the borderline middle, via the self-hosted LiteLLM gateway (OpenAI-compatible). The model
# behind the alias is gateway config — swappable without a rara-core change.
LITELLM_BASE_URL=http://litellm.internal:4000/v1
# Optional gateway master key (omit if the gateway runs keyless).
LITELLM_API_KEY=
# Gateway model alias for the judge. Default: claude-sonnet-4-6.
LITELLM_MODEL=claude-sonnet-4-6
