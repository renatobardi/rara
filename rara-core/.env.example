# rara-core — local env. Copy to .env (gitignored) and fill in real values.
#
# Phase 0 scaffold: rara-core only needs the database connection. The reconciler
# settings (poll interval, heartbeat timeout, Cloud Run Jobs activation) arrive with
# the reconciler in Phase 1 and will be documented here then.

# Neon PostgreSQL connection string (shared with the other rara agents; rara-core owns
# the control tables — capabilities, providers, flows, flow_steps, routing_policies,
# items, item_steps, gate_decisions, feedback, interest_profile).
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
