# /etc/rara-core/env — rara-core VPC deployment config.
# Copy to /etc/rara-core/env, fill in real values, chmod 640 ubuntu:ubuntu.

# --- Required ---------------------------------------------------------------

# Neon PostgreSQL connection string (shared database; rara-core owns the control tables).
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Bearer token for the control surface (HTTP + MCP adapter).
# Generate once: openssl rand -hex 32
SURFACE_TOKEN=

# Tailscale IP of this VM, e.g. 100.x.x.x, found with: tailscale ip -4
# MUST be the Tailscale address, NOT 0.0.0.0 — the surface must not listen on
# the public Oracle interface.
SURFACE_ADDR=100.x.x.x:8080

# --- Reconciler tuning (optional) -------------------------------------------

# How often the level-triggered loop runs. Default 30s.
RECONCILE_INTERVAL_SECONDS=30

# A claimed (running) step with no heartbeat for this long is assumed dead and
# re-queued. Default 600s (10 min).
RECONCILE_STALE_SECONDS=600

# --- Symmetric activation — Cloud Run Jobs (wakes cloudrun/on_demand providers) ---

CLOUD_RUN_PROJECT=oute-rara
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_JOB_PREFIX=rara-

# SA key for the activator (no metadata server on Oracle VM; key lives outside git).
# Provision: gcloud iam service-accounts keys create /tmp/rara-core-activator.json \
#              --iam-account=rara-core-activator@oute-rara.iam.gserviceaccount.com
# Install:  sudo mv /tmp/rara-core-activator.json /etc/rara-core/sa-key.json
#           sudo chmod 600 /etc/rara-core/sa-key.json
GOOGLE_APPLICATION_CREDENTIALS=/etc/rara-core/sa-key.json

# --- Symmetric activation tuning --------------------------------------------

# Per-wake HTTP timeout. Default 30s.
# ACTIVATE_TIMEOUT_SECONDS=30
