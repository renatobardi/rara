# rara-feed — local env. Copy to .env (gitignored) and fill in real values.

# Neon PostgreSQL connection string (shared with the other rara agents)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Max items taken per source per run.
FEED_BATCH_SIZE=25

# Best-effort full-text: fetch the article and extract the body when the feed ships
# no inline content. false = excerpt only (more robust).
FEED_FULLTEXT=true

# Restrict the run to a subset of source names (CSV). Empty = all sources.
# FEED_SOURCES_FILTER=OpenAI,Hacker News

# Hacker News (Algolia) minimum points for a story to be collected.
HN_MIN_POINTS=20

# Discard items older than this many days.
ITEM_MAX_AGE_DAYS=30

# HTTP fetch tuning.
FEED_HTTP_TIMEOUT=30
FEED_MAX_RETRIES=4

# --- Bright Data Web Unlocker (optional second fetch tier) ---
# Leave SCRAPE_PROVIDER unset for direct HTTP only. Set it to 'brightdata' to route
# sources whose feed_sources.fetch_strategy='unlocker' through the Web Unlocker; the
# rest still take the cheap direct path. BRIGHTDATA_TOKEN is then required.
# SCRAPE_PROVIDER=brightdata
# BRIGHTDATA_TOKEN=your-bright-data-api-token
# BRIGHTDATA_ZONE=web_unlocker1   # optional; defaults to web_unlocker1
# BRIGHTDATA_TIMEOUT=90           # optional; unlocker request timeout in seconds (default 90)
