# rara-dial — local env. Copy to .env (gitignored) and fill in real values.
# In production these come from GCP Secret Manager, not from a file.

# Neon PostgreSQL connection string (shared with the other rara agents)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Minimum published date for episodes (ISO format: YYYY-MM-DD). Episodes older than this
# are skipped during collection; episodes without a published date are always kept.
# Empty (default) = no floor, catalog all episodes.
PODCAST_MIN_PUBLISHED=
