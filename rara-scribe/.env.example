# rara-scribe — local env. Copy to .env (gitignored) and fill in real values.

# Neon PostgreSQL connection string (shared with rara-harvest / rara-shelf)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ASR engine: "groq" (default), "gemini" or "local" (whisper.cpp on this machine).
# "local" runs whisper-large-v3 offline — no API quota. When a GROQ_API_KEY is also
# set, "local" runs as primary with Groq as an automatic per-chunk fallback.
TRANSCRIBE_ENGINE=groq

# Groq API key (required for engine "groq"; also enables the Groq fallback under
# "local") — https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key

# Gemini API key (required only when TRANSCRIBE_ENGINE=gemini) — https://aistudio.google.com
# GEMINI_API_KEY=your-gemini-api-key

# whisper.cpp — required only when TRANSCRIBE_ENGINE=local. Reads mp3 chunks
# directly (no transcode). Install: brew install whisper-cpp
# WHISPER_CPP_BIN: the whisper.cpp CLI (Homebrew: whisper-cli).
# WHISPER_CPP_MODEL: absolute path to the ggml large-v3 model file (no default).
#   curl -L -o ~/whisper-models/ggml-large-v3.bin \
#     https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3.bin
# WHISPER_CPP_VAD_MODEL (optional): silero VAD model — trims silence/music and
#   cuts hallucinations. Leave unset to disable VAD.
#   curl -L -o ~/whisper-models/ggml-silero-v6.2.0.bin \
#     https://huggingface.co/ggml-org/whisper-vad/resolve/main/ggml-silero-v6.2.0.bin
# WHISPER_CPP_BIN=/opt/homebrew/bin/whisper-cli
# WHISPER_CPP_MODEL=/Users/you/whisper-models/ggml-large-v3.bin
# WHISPER_CPP_VAD_MODEL=/Users/you/whisper-models/ggml-silero-v6.2.0.bin

# Videos to transcribe per run. 25 is a sane default; raise freely (e.g. 100, 1000)
# to drain a large backlog faster — there is no hard cap.
BATCH_SIZE=25

# Absolute paths to yt-dlp and ffmpeg (resolved without $PATH lookup).
# Homebrew defaults shown — adjust if your install path differs.
# Find yours: which yt-dlp && which ffmpeg
YT_DLP_BIN=/opt/homebrew/bin/yt-dlp
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg

# Optional: contents of a Netscape cookies.txt.
# Not needed from a residential IP (no bot-check). Only useful if running from
# a datacenter or VPN that triggers YouTube's bot detection.
# YT_DLP_COOKIES=
