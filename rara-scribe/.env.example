# rara-scribe — local env. Copy to .env (gitignored) and fill in real values.
# In production these come from GCP Secret Manager, not from a file.

# Neon PostgreSQL connection string (shared with rara-harvest / rara-shelf)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ASR engine: "groq" (default) or "gemini"
TRANSCRIBE_ENGINE=groq

# Groq API key (required when TRANSCRIBE_ENGINE=groq) — https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key

# Gemini API key (required only when TRANSCRIBE_ENGINE=gemini) — https://aistudio.google.com
# GEMINI_API_KEY=your-gemini-api-key

# Videos to transcribe per run (bounds cost/time per Cloud Run execution)
BATCH_SIZE=25

# Optional: contents of a Netscape cookies.txt to let yt-dlp pass YouTube's
# datacenter-IP bot checks. Export from your browser; in production store it as
# the Secret Manager secret `yt-dlp-cookies`.
# YT_DLP_COOKIES=
