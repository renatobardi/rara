# rara-hone — the interest_profile reviser (periodic job, systemd timer on the VPC).
# Copy to .env and fill in. NEVER commit the real .env.

# --- Required ---------------------------------------------------------------
# Neon PostgreSQL connection string (the shared control database). hone reads the ACTIVE
# interest_profile + the feedback window and APPENDS a `proposed` revision; it never activates.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Narrator (optional) ----------------------------------------------------
# The LiteLLM gateway for the natural-language narrative of a proposed profile. If unset, a
# proposal still gets a deterministic template narrative — the structured revision is the part
# that must always work, so the narrator is best-effort.
# LITELLM_BASE_URL=https://litellm.internal/v1
# LITELLM_API_KEY=sk-...
# LITELLM_MODEL=claude-sonnet-4-6

# --- Trigger tuning (optional; override the conservative defaults) ----------
# Cadence: revise at least this often if there is new feedback (default 168h = weekly).
# REVISE_CADENCE_HOURS=168
# Threshold: ...or sooner, once this many new signals accumulate (default 20).
# REVISE_FEEDBACK_THRESHOLD=20
# Debounce: never revise within this window of the last revision (default 24h).
# REVISE_DEBOUNCE_HOURS=24
