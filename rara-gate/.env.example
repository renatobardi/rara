# rara-gate — the curation gate (claim-worker on the rara-addon SDK).
# One app serves BOTH gates (sift=gate_barato, assay=gate_rico) and both provider tiers by config.

# --- Required ---------------------------------------------------------------

# Neon PostgreSQL connection string (shared DB; gate reads interest_profile/gate_rules and the
# collector/scribe domain tables, and writes gate_decisions — all in the one Neon database).
# Use the DIRECT endpoint (host without "-pooler") — LLM-judge calls can take seconds;
# the pooler drops idle connections in that window.
DATABASE_URL=postgres://user:pass@ep-xxx-direct.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Which gate this process serves: the logical capability (never renamed).
#   gate_barato — judges item METADATA (title/channel) before paying for transcription
#   gate_rico   — judges the full TEXT before paying for distillation
SIFT_GATE=gate_barato

# The concrete provider this worker serves (the reconciler assigns steps to it). One app, several
# providers by deploy:
#   sift-cloud | sift-vpc | assay-cloud | assay-vpc
SIFT_PROVIDER=sift-cloud

# --- LLM-judge (the borderline middle only) ---------------------------------
# The self-hosted LiteLLM gateway (OpenAI-compatible). Required: a gate cannot judge without it.
LITELLM_BASE_URL=http://localhost:4000/v1
# Optional gateway master key (omitted from the request when empty).
LITELLM_API_KEY=
# Gateway model alias (defaults to claude-sonnet-4-6).
# NOTE: Cloud Run deployments pin gates to groq-fast (llama-3.1-8b-instant) in deploy-gate.yml —
# 8b is enough for a JSON judge and avoids quota contention with distill (groq-llama/70b). Change
# here for local dev only; to change prod, edit the workflow YAML directly.
LITELLM_MODEL=groq-fast

# --- Optional: resident mode + symmetric activation -------------------------
# Default (all unset) is on_demand: drain the queue once and exit (the woken Cloud Run job).
# Set a poll interval and/or a poke listener to run resident (e.g. the *-local providers on the Mac).
# WORK_POLL_INTERVAL=30s          # safety-net poll cadence (Go duration)
# POKE_ADDR=:8090                 # tailnet-only HTTP listener; POST /poke drains on demand
# POKE_TOKEN=change-me            # Bearer token authenticating the poke
