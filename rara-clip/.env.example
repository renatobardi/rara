# rara-clip — local env. Copy to .env (gitignored) and fill in real values.
# In production these come from GCP Secret Manager, not from a file.

# Neon PostgreSQL connection string (shared with the other rara agents)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Bright Data CLI (the `bdata` agent skill's tool). The collector shells out to it; it reads its
# own API key from BRIGHTDATA_API_KEY, so rara-clip never handles the credential.
BDATA_BIN=bdata
BRIGHTDATA_API_KEY=your-bright-data-api-key

# Optional: the pipeline subcommand + flags (the input URLs are appended as trailing args).
BRIGHTDATA_LINKEDIN_ARGS=pipelines linkedin_person_profile --json

# The LinkedIn profile/post URLs to collect (comma- or newline-separated).
BRIGHTDATA_LINKEDIN_URLS=https://www.linkedin.com/in/example/recent-activity/all/
