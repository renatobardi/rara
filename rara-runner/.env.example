# rara-runner agent — config is environment-only; required vars fail fast at startup.

# Tailnet bind address (host:port). NEVER 0.0.0.0 or a bare ":port" — the agent runs containers
# on a personal machine, so it must only be reachable over the tailnet. Use the host's tailnet IP.
RUNNER_ADDR=100.64.0.1:8473

# Shared tailnet Bearer token. Auth fails CLOSED: an empty token rejects every request.
# Generate a strong one: `openssl rand -hex 32`.
RUNNER_TOKEN=replace-with-a-long-random-secret

# Allowlist of runnable images: comma-separated app=image pairs, image pinned by digest.
# An app not listed here can never be launched, and the body never names an image.
RUNNER_ALLOWED_IMAGES=rara-distill=us-docker.pkg.dev/PROJECT/rara/rara-distill@sha256:...,rara-sift=us-docker.pkg.dev/PROJECT/rara/rara-sift@sha256:...

# Container launcher binary. Default "docker"; set "podman" for rootless on the Mac (no root daemon,
# so a container escape is contained to the user namespace). Must be "docker", "podman", or an
# ABSOLUTE path — a relative name is rejected so it can't resolve an attacker-planted binary on PATH.
# RUNNER_DOCKER_BIN=docker
