# rara-runner dispatch — config is environment-only; required vars fail fast at startup.
# Installed on the VPC as /etc/rara-runner/env (chmod 640, gitignored).
#
# Prod state is cloud-run-only: dispatch wakes GCP Cloud Run jobs via jobs:run.
# RUNNER_TOKEN is intentionally NOT set here — no host (VPC/Mac) transport yet,
# so leaving it unset keeps dispatch cloud-run-only (the agent ships separately).

# Neon DSN the dispatcher reads assigned steps from.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Cloud Run target. PROJECT and REGION are all-or-nothing (both set, or neither).
CLOUD_RUN_PROJECT=your-gcp-project
CLOUD_RUN_REGION=us-central1

# Job name prefix: provider "rara-distill" -> job "rara-distill". Workers are named rara-*.
CLOUD_RUN_JOB_PREFIX=rara-

# Reuse the SA key rara-core already uses (SA rara-core-activator holds run.invoker).
# ADC reads this file to mint the bearer for jobs:run.
GOOGLE_APPLICATION_CREDENTIALS=/etc/rara-core/sa-key.json

# Loop cadence in seconds (positive integer). The binary default is 5 when unset; this example
# overrides it to 10 for prod.
DISPATCH_INTERVAL_SECONDS=10
