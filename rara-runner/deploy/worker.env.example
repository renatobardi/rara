# rara-runner worker base env — injected into EVERY container started by the agent.
# Installed on the VPC as /etc/rara-runner/worker.env (chmod 600).
# Contains secrets — MUST be chmod 600 or 640.
#
# Per-placement overrides (CURATE_ENGINE, LITELLM_MODEL, provider names, etc.) are
# carried in the provider's body_env column and injected by the dispatcher at wake
# time — they are merged on top of this file (body wins on conflict).

# Shared Neon PostgreSQL connection string (all workers).
DATABASE_URL=postgresql://user:password@host/dbname

# LiteLLM gateway running as a Docker container on this host.
# Reachable from worker containers via the docker0 bridge gateway address.
# Ensure the nftables rule allows docker0 → host traffic on this port:
#   sudo nft insert rule ip filter INPUT iifname "docker0" tcp dport 4010 accept
LITELLM_BASE_URL=http://172.17.0.1:4010

# LiteLLM master key (must match the running LiteLLM container config).
LITELLM_API_KEY=change-me
