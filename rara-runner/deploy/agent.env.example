# rara-runner agent — config is environment-only; required vars fail fast at startup.
# Installed on the VPC as /etc/rara-runner/agent.env (chmod 640, gitignored).
# This file contains secrets (RUNNER_TOKEN, etc.) — MUST be chmod 600 or 640.
# The agent refuses to start if RUNNER_WORKER_ENV_FILE has world-readable permissions.
#
# The agent binds on the tailnet only, so RUNNER_ADDR must name the Tailscale IP
# explicitly — a wildcard (0.0.0.0, ::, or a bare :port) is refused at startup.

# Tailnet bind address. Use the host's Tailscale IP (100.x.x.x), not 0.0.0.0.
RUNNER_ADDR=100.x.x.x:8473

# Shared Bearer token. Must match RUNNER_TOKEN on rara-runner dispatch.
# Empty value rejects every request (fail-closed).
RUNNER_TOKEN=change-me

# Image allowlist: comma-separated app=image pairs.
# Each image MUST be pinned by digest (@sha256:...) — an unpinned image fails startup.
# A request names the app key; the runner resolves the image — no arbitrary image can be run.
# Format: app=registry/image@sha256:DIGEST,app2=registry/image2@sha256:DIGEST
#
# IMPORTANT — use the manifest-list digest, NOT a per-platform digest.
# The per-platform sha256 (listed by "gcloud artifacts docker images list" without --include-tags)
# is amd64-only. On an ARM host (Oracle A1) it causes "exec format error" at container start.
# Get the manifest-list digest with:
#   gcloud artifacts docker images list REGISTRY/IMAGE --include-tags --filter='tags:*' \
#     --sort-by="~UPDATE_TIME" --format='value(version)' --limit=1
# Validate multi-arch before updating:
#   docker manifest inspect REGISTRY/IMAGE@sha256:DIGEST | python3 -c \
#     "import sys,json; [print(m['platform']) for m in json.load(sys.stdin)['manifests']]"
RUNNER_ALLOWED_IMAGES=rara-distill=us-docker.pkg.dev/YOUR_PROJECT/rara/rara-distill@sha256:DIGEST

# Docker (or Podman) binary. Defaults to "docker" when unset.
# Must be "docker", "podman", or an absolute path — a relative name is refused (PATH hijack).
# podman is rootless: a container escape stays in the user namespace instead of reaching root.
RUNNER_DOCKER_BIN=docker

# Path to a KEY=VAL file injected as env into every container started by this agent.
# Contains host-side secrets: DATABASE_URL, LITELLM_BASE_URL, API keys, etc.
# MUST be chmod 600 or 640 — the file contains secrets.
# Body env from POST /run is merged on top (body wins on conflict, so callers can override
# non-secret config but secrets stay host-side only).
# Missing file or unset var → no base env; agent still starts.
RUNNER_WORKER_ENV_FILE=/etc/rara-runner/worker.env

# Docker credential directory. Required when the service runs under systemd with ProtectHome=true
# (the default hardening for rara-runner-agent.service), which makes ~/.docker/ inaccessible.
# Copy the credentials once: sudo mkdir -p /etc/rara-runner/docker && \
#   sudo cp ~/.docker/config.json /etc/rara-runner/docker/config.json && \
#   sudo chown -R ubuntu:ubuntu /etc/rara-runner/docker && sudo chmod 600 /etc/rara-runner/docker/config.json
DOCKER_CONFIG=/etc/rara-runner/docker
