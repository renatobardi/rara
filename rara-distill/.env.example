# rara-distill — local env. Copy to .env (gitignored) and fill in real values.

# Neon PostgreSQL connection string (shared with the other rara agents)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Curation LLM engine: "gemini" (default), "claude", "groq" or "litellm".
# Prefer "litellm" in 2.0: distill speaks OpenAI-compatible to a self-hosted LiteLLM
# gateway and the real model becomes a gateway config alias (no vendor lock-in, no markup).
CURATE_ENGINE=gemini

# Gemini API key (required when CURATE_ENGINE=gemini) — https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Anthropic API key (required when CURATE_ENGINE=claude) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key

# Groq API key (required when CURATE_ENGINE=groq) — https://console.groq.com
# GROQ_API_KEY=gsk_your-groq-api-key

# LiteLLM gateway (required when CURATE_ENGINE=litellm). BASE_URL is the gateway's
# OpenAI-compatible base (it appends /chat/completions). API_KEY is the optional gateway
# master key — omit it if the self-hosted gateway runs keyless. MODEL is the gateway alias
# (defined in litellm/config.yaml), e.g. claude-sonnet-4-6. See litellm/README.md.
# LITELLM_BASE_URL=http://litellm:4000/v1
# LITELLM_API_KEY=sk-your-gateway-master-key
# LITELLM_MODEL=claude-sonnet-4-6

# Optional model overrides (defaults are sane current models per engine).
# GEMINI_MODEL=gemini-2.5-pro
# CLAUDE_MODEL=claude-sonnet-4-6
# GROQ_MODEL=openai/gpt-oss-120b

# Curation recipe (the Fabric-style library lives in patterns/ contexts/ strategies/).
# One pattern = single pass; many (CSV) = a session chain where each stage sees the
# previous stage's output.
DISTILL_PATTERNS=extract_wisdom
# Optional reference context injected into every call (file in contexts/<name>.md).
# DISTILL_CONTEXT=software-ai
# Optional reasoning strategy wrapping the pattern (file in strategies/<name>.md).
# DISTILL_STRATEGY=cot

# Docs to distill per run. The code default is 1; the deployed Cloud Run Job uses 25
# (see deploy-distill.yml) to drain the backlog.
DISTILL_BATCH_SIZE=25

# Source lane: which upstream the work-queue reads.
#   transcripts (default) — rara-scribe transcripts, with the DISTILL_PATTERNS recipe.
#   news                  — rara-feed news_items (status='ready'), with a fixed
#                           summarize_news + software-ai recipe (DISTILL_PATTERNS/
#                           CONTEXT/STRATEGY are ignored in this lane).
# Run the news lane as its own Cloud Run Job + scheduler.
DISTILL_SOURCE=transcripts
