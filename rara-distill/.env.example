# rara-distill — local env. Copy to .env (gitignored) and fill in real values.

# Neon PostgreSQL connection string (shared with the other rara agents)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Curation LLM engine: "gemini" (default), "claude", "groq" or "litellm".
# Prefer "litellm" in 2.0: distill speaks OpenAI-compatible to a self-hosted LiteLLM
# gateway and the real model becomes a gateway config alias (no vendor lock-in, no markup).
CURATE_ENGINE=gemini

# Gemini API key (required when CURATE_ENGINE=gemini) — https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Anthropic API key (required when CURATE_ENGINE=claude) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key

# Groq API key (required when CURATE_ENGINE=groq) — https://console.groq.com
# GROQ_API_KEY=gsk_your-groq-api-key

# LiteLLM gateway (required when CURATE_ENGINE=litellm). BASE_URL is the gateway's
# OpenAI-compatible base (it appends /chat/completions). API_KEY is the optional gateway
# master key — omit it if the self-hosted gateway runs keyless. MODEL is the gateway alias
# (defined in litellm/config.yaml), e.g. claude-sonnet-4-6. See litellm/README.md.
# LITELLM_BASE_URL=http://litellm:4000/v1
# LITELLM_API_KEY=sk-your-gateway-master-key
# LITELLM_MODEL=claude-sonnet-4-6

# Optional model overrides (defaults are sane current models per engine).
# GEMINI_MODEL=gemini-2.5-pro
# CLAUDE_MODEL=claude-sonnet-4-6
# GROQ_MODEL=openai/gpt-oss-120b

# --- Worker identity (bridge-total claim-worker on the rara-addon SDK) ---
# DISTILL_PROVIDER (required): the provider this worker serves. The reconciler assigns destilar
# steps to a provider and this worker claims only its own (capability=destilar, assigned_provider).
# e.g. distill (third-party LLM on Cloud Run) | distill-local (self-host on the VPC).
DISTILL_PROVIDER=distill

# Activation mode (optional). Default is on_demand: drain the queue once and exit (the woken Cloud
# Run Job). Set either of these to run resident with symmetric activation:
#   WORK_POLL_INTERVAL — safety-net poll cadence (Go duration "30s"/"2m", or bare seconds).
#   POKE_ADDR/POKE_TOKEN — a tailnet HTTP listener that drains on POST /poke (Bearer POKE_TOKEN).
# WORK_POLL_INTERVAL=30s
# POKE_ADDR=:7700
# POKE_TOKEN=your-shared-poke-token

# --- Default curation recipe (the per-item recipe normally comes from CONFIG) ---
# The recipe (pattern chain + context + strategy) is normally carried by the flow's destilar step
# (flow_steps.options.recipe) and read per item — e.g. the old "news" lane is a flow whose destilar
# step sets {"recipe":{"patterns":["summarize_news"],"context":"software-ai"}}. These env values are
# only the FALLBACK default, used when a step carries no recipe.
# The Fabric-style library lives in patterns/ contexts/ strategies/. One pattern = single pass;
# many (CSV) = a session chain where each stage sees the previous stage's output.
DISTILL_PATTERNS=extract_wisdom
# Optional reference context injected into every call (file in contexts/<name>.md).
# DISTILL_CONTEXT=software-ai
# Optional reasoning strategy wrapping the pattern (file in strategies/<name>.md).
# DISTILL_STRATEGY=cot
