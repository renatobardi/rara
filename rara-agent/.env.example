# Required
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
CORE_URL=https://core.rara.internal
CORE_TOKEN=secret

# Optional
AGENT_POLL_INTERVAL_S=5        # poll cadence in seconds (default 5)
CLAUDE_BIN=claude               # path to claude CLI binary (default: claude in PATH)
AGENT_WORK_BASE=/tmp/rara-agent # base dir for task workdirs (default: /tmp/rara-agent)
